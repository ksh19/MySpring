<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="kr.board.mapper.BoardMapper">

	<select id="getList" resultType="kr.spring.entity.Board">
		select * from tboard
	</select>
	
	<insert id="boardInsert" parameterType="kr.spring.entity.Board">
		insert into tboard(title, content, writer)
		values(#{title}, #{content}, #{writer})
	</insert>
	
	<select id="boardContent" resultType="kr.spring.entity.Board" parameterType="int">
		select * from tboard where idx=#{idx}
	</select>
	
	<update id="count" parameterType="int">
		update tboard set count = count + 1 where idx=#{idx}
	</update>
	
	<delete id="boardDelete" parameterType="int">
		delete from tboard where idx=#{idx}
	</delete>
	
	<update id="boardUpdate" parameterType="kr.spring.entity.Board">
		update tboard
		set title = #{title}, content = #{content}, writer = #{writer}
		where idx = #{idx}
	</update>
	
</mapper>